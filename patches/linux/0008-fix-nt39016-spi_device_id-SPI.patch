serial.log: SPI driver nt39016 has no spi_device_id for kingdisplay,kd035g6-54nt

Co-Authored-By: Claude Fable 5 <noreply@anthropic.com>
---
 drivers/gpu/drm/panel/panel-novatek-nt39016.c | 7 +++++++
 1 file changed, 7 insertions(+)

diff --git a/drivers/gpu/drm/panel/panel-novatek-nt39016.c b/drivers/gpu/drm/panel/panel-novatek-nt39016.c
index a629976ba..3df66ae76 100644
--- a/drivers/gpu/drm/panel/panel-novatek-nt39016.c
+++ b/drivers/gpu/drm/panel/panel-novatek-nt39016.c
@@ -341,11 +341,18 @@ static const struct of_device_id nt39016_of_match[] = {
 };
 MODULE_DEVICE_TABLE(of, nt39016_of_match);
 
+static const struct spi_device_id nt39016_spi_ids[] = {
+	{ "kd035g6-54nt", (kernel_ulong_t)&kd035g6_info },
+	{ /* sentinel */ }
+};
+MODULE_DEVICE_TABLE(spi, nt39016_spi_ids);
+
 static struct spi_driver nt39016_driver = {
 	.driver = {
 		.name = "nt39016",
 		.of_match_table = nt39016_of_match,
 	},
+	.id_table = nt39016_spi_ids,
 	.probe = nt39016_probe,
 	.remove = nt39016_remove,
 };
