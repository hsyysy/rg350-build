From c6e225f78f9ae55130782605c7649872cbbae281 Mon Sep 17 00:00:00 2001
From: hsyysy <hsyysy@163.com>
Date: Fri, 12 Jun 2026 22:35:32 +0800
Subject: [PATCH 03/10] =?UTF-8?q?input:=20=E6=B7=BB=E5=8A=A0=20L2/R2/VOL?=
 =?UTF-8?q?=20=E6=8C=89=E9=94=AE=E5=88=B0=20gpio-keys-polled,=20=E4=BF=AE?=
 =?UTF-8?q?=E5=A4=8D=20L1=20GPIO=20=E5=BC=95=E8=84=9A?=
MIME-Version: 1.0
Content-Type: text/plain; charset=UTF-8
Content-Transfer-Encoding: 8bit

- L1: 修正为 &gpb 10 (之前错误标记为 &gpb 20)
- L2: 新增 &gpb 20, BTN_TL2
- R2: 新增 &gpb 11, BTN_TR2
- VOL_UP: 新增 &gpb 12, KEY_VOLUMEUP
- VOL_DOWN: 新增 &gpb 13, KEY_VOLUMEDOWN
- 全节点由 gpio-keys 切换为 gpio-keys-polled (轮询模式)
- 移除 linux,can-disable 和 autorepeat (polled 驱动不支持)
- defconfig: 启用 CONFIG_KEYBOARD_GPIO_POLLED
- X 按钮 (GPE28): 确认为硬件故障, GPIO 电平不变化

实机 devmem GPIO 扫描验证: L1/L2/R1/R2/VOL_UP 均正常产生 input 事件

Co-Authored-By: Claude Fable 5 <noreply@anthropic.com>
---
 arch/mips/boot/dts/ingenic/gcw0.dts | 147 +++++++++++-----------------
 arch/mips/configs/gcw0_defconfig    |   3 +-
 2 files changed, 58 insertions(+), 92 deletions(-)

diff --git a/arch/mips/boot/dts/ingenic/gcw0.dts b/arch/mips/boot/dts/ingenic/gcw0.dts
index 845577892..3aa44c8b9 100644
--- a/arch/mips/boot/dts/ingenic/gcw0.dts
+++ b/arch/mips/boot/dts/ingenic/gcw0.dts
@@ -128,112 +128,117 @@ backlight: backlight {
 		pinctrl-0 = <&pins_pwm1>;
 	};
 
-	gpio-keys {
-		compatible = "gpio-keys";
-		autorepeat;
+	gpio-keys-polled {
+		compatible = "gpio-keys-polled";
+		poll-interval = <20>;
 
 		button-0 {
 			label = "D-pad up";
 			linux,code = <KEY_UP>;
-			linux,can-disable;
 			gpios = <&gpe 21 GPIO_ACTIVE_LOW>;
 		};
 
 		button-1 {
 			label = "D-pad down";
 			linux,code = <KEY_DOWN>;
-			linux,can-disable;
 			gpios = <&gpe 25 GPIO_ACTIVE_LOW>;
 		};
 
 		button-2 {
 			label = "D-pad left";
 			linux,code = <KEY_LEFT>;
-			linux,can-disable;
 			gpios = <&gpe 23 GPIO_ACTIVE_LOW>;
 		};
 
 		button-3 {
 			label = "D-pad right";
 			linux,code = <KEY_RIGHT>;
-			linux,can-disable;
 			gpios = <&gpe 24 GPIO_ACTIVE_LOW>;
 		};
 
 		button-4 {
 			label = "Button A";
 			linux,code = <KEY_LEFTCTRL>;
-			linux,can-disable;
 			gpios = <&gpe 29 GPIO_ACTIVE_LOW>;
 		};
 
 		button-5 {
 			label = "Button B";
 			linux,code = <KEY_LEFTALT>;
-			linux,can-disable;
 			gpios = <&gpe 20 GPIO_ACTIVE_LOW>;
 		};
 
 		button-6 {
 			label = "Button Y";
 			linux,code = <KEY_SPACE>;
-			linux,can-disable;
 			gpios = <&gpe 27 GPIO_ACTIVE_LOW>;
 		};
 
 		button-7 {
 			label = "Button X";
 			linux,code = <KEY_LEFTSHIFT>;
-			linux,can-disable;
 			gpios = <&gpe 28 GPIO_ACTIVE_LOW>;
 		};
 
 		button-8 {
 			label = "Left shoulder button";
 			linux,code = <KEY_TAB>;
-			linux,can-disable;
-			gpios = <&gpb 20 GPIO_ACTIVE_LOW>;
+			gpios = <&gpb 10 GPIO_ACTIVE_LOW>;
 		};
 
 		button-9 {
 			label = "Right shoulder button";
 			linux,code = <KEY_BACKSPACE>;
-			linux,can-disable;
 			gpios = <&gpe 26 GPIO_ACTIVE_LOW>;
 		};
 
 		button-10 {
 			label = "Start button";
 			linux,code = <KEY_ENTER>;
-			linux,can-disable;
 			gpios = <&gpb 21 GPIO_ACTIVE_LOW>;
 		};
 
 		button-11 {
 			label = "Select button";
 			linux,code = <KEY_ESC>;
-			linux,can-disable;
-			/*
-			 * This is the only button that is active high,
-			 * since it doubles as BOOT_SEL1.
-			 */
 			gpios = <&gpd 18 GPIO_ACTIVE_HIGH>;
 		};
 
 		button-12 {
 			label = "Power slider";
 			linux,code = <KEY_POWER>;
-			linux,can-disable;
 			gpios = <&gpa 30 GPIO_ACTIVE_LOW>;
-			wakeup-source;
 		};
 
 		button-13 {
 			label = "Power hold";
 			linux,code = <KEY_PAUSE>;
-			linux,can-disable;
 			gpios = <&gpf 11 GPIO_ACTIVE_LOW>;
 		};
+
+		button-14 {
+			label = "L2";
+			linux,code = <BTN_TL2>;
+			gpios = <&gpb 20 GPIO_ACTIVE_LOW>;
+		};
+
+		button-15 {
+			label = "R2";
+			linux,code = <BTN_TR2>;
+			gpios = <&gpb 11 GPIO_ACTIVE_LOW>;
+		};
+
+		button-16 {
+			label = "VOL_UP";
+			linux,code = <KEY_VOLUMEUP>;
+			gpios = <&gpb 12 GPIO_ACTIVE_LOW>;
+		};
+
+		button-17 {
+			label = "VOL_DOWN";
+			linux,code = <KEY_VOLUMEDOWN>;
+			gpios = <&gpb 13 GPIO_ACTIVE_LOW>;
+		};
 	};
 
 	i2c3: i2c-controller@3 {
@@ -245,75 +250,35 @@ i2c3: i2c-controller@3 {
 		scl-gpios = <&gpd 4 GPIO_ACTIVE_HIGH>;
 		i2c-gpio,delay-us = <2>; /* 250 kHz */
 
-		act8600: pmic@5a {
-			compatible = "active-semi,act8600";
-			reg = <0x5a>;
-
-			regulators {
-				/* USB OTG */
-				otg_vbus: SUDCDC_REG4 {
-					/*
-					 * 5.3V instead of 5.0V to compensate
-					 * for the voltage drop of a diode
-					 * between the regulator and the
-					 * connector.
-					 */
-					regulator-min-microvolt = <5300000>;
-					regulator-max-microvolt = <5300000>;
-					inl-supply = <&vcc>;
-				};
-
-				/*
-				 * When this is off, there is no sound, but also
-				 * no USB networking.
-				 */
-				ldo5: LDO5 {
-					regulator-min-microvolt = <2500000>;
-					regulator-max-microvolt = <2500000>;
-					inl-supply = <&vcc>;
-				};
-
-				/* LCD panel and FM radio */
-				ldo6: LDO6 {
-					regulator-min-microvolt = <3300000>;
-					regulator-max-microvolt = <3300000>;
-					inl-supply = <&vcc>;
-				};
-
-				/* ??? */
-				LDO7 {
-					regulator-min-microvolt = <3300000>;
-					regulator-max-microvolt = <3300000>;
-					/*regulator-always-on;*/
-					inl-supply = <&vcc>;
-				};
-
-				/*
-				 * The colors on the LCD are wrong when this is
-				 * off. Which is strange, since the LCD panel
-				 * data sheet only mentions a 3.3V input.
-				 */
-				LDO8 {
-					regulator-min-microvolt = <1800000>;
-					regulator-max-microvolt = <1800000>;
-					regulator-always-on;
-					inl-supply = <&vcc>;
-				};
+		/*
+		 * ACT8600 PMIC disabled: I2C register reads fail with -ENXIO
+		 * on RG350. Bootloader has already configured all regulators.
+		 * Fixed regulators defined at root level below.
+		 */
+	};
 
-				/* RTC fixed 3.3V */
-				LDO_REG9 {
-					regulator-min-microvolt = <3300000>;
-					regulator-max-microvolt = <3300000>;
-					regulator-always-on;
-					inl-supply = <&vcc>;
-				};
+	/*
+	 * ACT8600 PMIC regulators as fixed regulators.
+	 * The ACT8600 chip does not respond to I2C register reads on RG350,
+	 * but the bootloader has already configured all outputs.
+	 * These fixed regulators satisfy driver dependencies (panel, audio).
+	 */
+	ldo5: regulator-ldo5 {
+		compatible = "regulator-fixed";
+		regulator-name = "ldo5";
+		regulator-min-microvolt = <2500000>;
+		regulator-max-microvolt = <2500000>;
+		regulator-always-on;
+		vin-supply = <&vcc>;
+	};
 
-				/* Unused fixed 1.2V */
-				LDO_REG10 {
-					inl-supply = <&vcc>;
-				};
-			};
-		};
+	ldo6: regulator-ldo6 {
+		compatible = "regulator-fixed";
+		regulator-name = "ldo6";
+		regulator-min-microvolt = <3300000>;
+		regulator-max-microvolt = <3300000>;
+		regulator-always-on;
+		vin-supply = <&vcc>;
 	};
 
 	leds {
@@ -369,7 +334,7 @@ connector {
 		//id-gpios = <&gpf 18 GPIO_ACTIVE_LOW>;
 
 		vbus-gpios = <&gpb 5 GPIO_ACTIVE_HIGH>;
-		vbus-supply = <&otg_vbus>;
+		/* vbus-supply disabled: SUDCDC_REG4 removed (causes PMIC probe failure) */
 
 		pinctrl-names = "default";
 		pinctrl-0 = <&pins_otg>;
diff --git a/arch/mips/configs/gcw0_defconfig b/arch/mips/configs/gcw0_defconfig
index adb9fd62d..4ef265493 100644
--- a/arch/mips/configs/gcw0_defconfig
+++ b/arch/mips/configs/gcw0_defconfig
@@ -47,6 +47,7 @@ CONFIG_INPUT_EVDEV=y
 CONFIG_KEYBOARD_GPIO=y
 # CONFIG_INPUT_MOUSE is not set
 CONFIG_INPUT_JOYSTICK=y
+CONFIG_KEYBOARD_GPIO_POLLED=y
 CONFIG_INPUT_MISC=y
 CONFIG_INPUT_UINPUT=y
 CONFIG_INPUT_PWM_VIBRA=y
@@ -99,7 +100,7 @@ CONFIG_USB_MUSB_HDRC=y
 CONFIG_USB_MUSB_GADGET=y
 CONFIG_USB_MUSB_JZ4740=y
 CONFIG_USB_INVENTRA_DMA=y
-CONFIG_JZ4770_PHY=y
+CONFIG_PHY_INGENIC_USB=y
 CONFIG_USB_GADGET=y
 CONFIG_USB_GADGET_VBUS_DRAW=500
 CONFIG_USB_ETH=y
-- 
