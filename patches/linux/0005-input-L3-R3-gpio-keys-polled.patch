Content-Type: text/plain; charset=UTF-8
Content-Transfer-Encoding: 8bit

- L3: &gpb 14, BTN_THUMBL (实机 devmem 扫描确认)
- R3: &gpb 15, BTN_THUMBR (实机 devmem 扫描确认)
- 修正 VOL_DOWN 按钮编号 (button-17 → button-19, 避免重复)

之前错误排除为硬件不存在, 实机验证确认摇杆可按下.

Co-Authored-By: Claude Fable 5 <noreply@anthropic.com>
---
 arch/mips/boot/dts/ingenic/gcw0.dts | 14 +++++++++++++-
 1 file changed, 13 insertions(+), 1 deletion(-)

diff --git a/arch/mips/boot/dts/ingenic/gcw0.dts b/arch/mips/boot/dts/ingenic/gcw0.dts
index 328896492..ff54556ee 100644
--- a/arch/mips/boot/dts/ingenic/gcw0.dts
+++ b/arch/mips/boot/dts/ingenic/gcw0.dts
@@ -229,12 +229,24 @@ button-15 {
 		};
 
 		button-16 {
+			label = "L3";
+			linux,code = <BTN_THUMBL>;
+			gpios = <&gpb 14 GPIO_ACTIVE_LOW>;
+		};
+
+		button-17 {
+			label = "R3";
+			linux,code = <BTN_THUMBR>;
+			gpios = <&gpb 15 GPIO_ACTIVE_LOW>;
+		};
+
+		button-18 {
 			label = "VOL_UP";
 			linux,code = <KEY_VOLUMEUP>;
 			gpios = <&gpb 12 GPIO_ACTIVE_LOW>;
 		};
 
-		button-17 {
+		button-19 {
 			label = "VOL_DOWN";
 			linux,code = <KEY_VOLUMEDOWN>;
 			gpios = <&gpb 13 GPIO_ACTIVE_LOW>;
-- 
